rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return isSignedIn() && request.auth.token.role != null
        ? request.auth.token.role
        : "";
    }

    function isAdmin() {
      return role() == "admin" || (isSignedIn() && request.auth.token.email == "selectorzero@gmail.com");
    }

    function isEditor() {
      return role() == "editor" || isAdmin();
    }

    match /plants/{plantId} {
      allow read: if resource.data.isPublic == true
                  || role() in ["member", "editor", "admin"]
                  || isAdmin();
      allow create, update, delete: if isEditor();
    }

    match /profiles/{userId} {
      allow read, update: if isSignedIn() && request.auth.uid == userId;
      allow read, update: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
    }

    match /memberApplications/{docId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /favorites/{docId} {
      allow read, write: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid;
    }

    match /notifications/{docId} {
      allow read, update: if isSignedIn() &&
        resource.data.uid == request.auth.uid;
      allow create, delete: if isAdmin();
    }
  }
}

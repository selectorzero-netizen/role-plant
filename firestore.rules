rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return isSignedIn() && request.auth.token.role != null
        ? request.auth.token.role
        : "";
    }

    function isAdmin() {
      return role() == "admin";
    }

    function isEditor() {
      return role() == "editor" || isAdmin();
    }

    match /plants/{plantId} {
      allow read: if resource.data.isPublic == true
                  || role() in ["member", "editor", "admin"]
                  || isAdmin();
      allow create, update, delete: if isEditor();
    }

    match /profiles/{userId} {
      allow read, update: if isSignedIn() && request.auth.uid == userId;
      allow read, update: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
    }

    match /memberApplications/{docId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isEditor();
    }

    match /inquiries/{docId} {
      allow create: if 
        request.resource.data.keys().hasAll(['brandName', 'contactName', 'email', 'details', 'status', 'createdAt']) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.brandName is string && request.resource.data.brandName.size() > 0 && request.resource.data.brandName.size() <= 100 &&
        request.resource.data.email is string && request.resource.data.email.matches('^[^@]+@[^@]+\\.[a-zA-Z]{2,}$') &&
        request.resource.data.details is string && request.resource.data.details.size() <= 2000;
      allow read, update, delete: if isEditor();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if isEditor();
    }

    match /favorites/{docId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /notifications/{docId} {
      allow read, update: if isSignedIn() &&
        resource.data.uid == request.auth.uid;
      allow create, delete: if isEditor();
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() 
             && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. Profiles (Users)
    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // 首次登入建檔：強制限定建立自己的 profile，且值必須妥善預設為 member/pending
      allow create: if isOwner(userId) 
                    && request.resource.data.role == 'member' 
                    && request.resource.data.status == 'pending';
                    
      // 更新：Admin 擁有全開寫入權限；User 只能修改「非權限參數」，且其本身狀態必須已被 approve 才能做更動 (涵蓋改名、Favorites 陣列)
      allow update: if isAdmin() || (isOwner(userId) 
                    && request.resource.data.role == resource.data.role 
                    && request.resource.data.status == resource.data.status
                    && resource.data.status == 'approved');
      
      allow delete: if isAdmin();
    }

    // 2. Plants Collection (Public viewing, admin writing)
    match /plants/{plantId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Member Applications
    match /applications/{appId} {
      // 建立：只能建立掛載在自己 UID 名下的申請，且本身 profile 必須是 approved。
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid 
                    && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.status == 'approved';
                    
      // 讀取：允許 User 自行讀取本身的歷史清單，Admin 可全讀。
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      
      allow update, delete: if isAdmin();
    }
    
    // 4. Fallback default (Close all unexpected paths, allow Admin superuser)
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
